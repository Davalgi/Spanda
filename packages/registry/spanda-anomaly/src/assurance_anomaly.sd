module assurance.anomaly;

extern python fn onnx_anomaly_infer(features: String) -> Float;

/** Threshold + EMA volatility scan (runtime dispatch adds optional ONNX). */
export fn scan_learned(detector: String, observed: Float, volatility: Float) -> Int {
    if observed < 0.85 || volatility > 0.25 {
        return 1;
    }
    return 0;
}

/** ONNX-backed scan when `features` is JSON: detector, observed, volatility. */
export fn scan_learned_onnx(features: String) -> Int {
    let score = onnx_anomaly_infer(features);
    if score > 0.5 {
        return 1;
    }
    return 0;
}

export fn backend_name() -> String {
    return "assurance.anomaly";
}
