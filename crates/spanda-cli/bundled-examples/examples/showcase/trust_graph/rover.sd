// Trust graph showcase — mission → capability → hardware → package → provider chain.
//
//   spanda trust-graph examples/showcase/trust_graph/rover.sd
//   spanda trust-graph examples/showcase/trust_graph/rover.sd --format mermaid
//   spanda trust-graph examples/showcase/trust_graph/rover.sd --json

import trust.jetson;

hardware RoverV1 {
  sensors [ GPS, Lidar, Camera ];
  actuators [ DifferentialDrive ];
  connectivity [ WiFi, LTE ];
}

kill_switch EmergencyStop {
  priority: critical;
  action { emergency_stop; }
}

robot Rover {
  uses hardware RoverV1;
  sensor gps: GPS;
  sensor lidar: Lidar;
  sensor camera: Camera;
  actuator wheels: DifferentialDrive;

  exposes capabilities [
    gps_navigation,
    obstacle_avoidance,
    telemetry_streaming
  ];

  mission Patrol {
    requires capabilities [ gps_navigation, obstacle_avoidance ];
    patrol_loop;
  }

  safety {
    max_speed = 0.8 m/s;
    stop_if lidar.nearest_distance < 0.5 m;
  }

  mode caution_mode { wheels.drive(linear: 0.1 m/s, angular: 0.0 rad/s); }

  behavior patrol_loop() {
    loop every 100ms {
      let scan = lidar.read();
      let _ = scan;
      wheels.drive(linear: 0.2 m/s, angular: 0.0 rad/s);
    }
  }
}

health_check RoverHealth for robot Rover {
  check gps.status == Healthy;
  check lidar.status == Healthy;
  check camera.status == Healthy;
}

health_policy RoverPolicy {
  on Degraded { enter caution_mode; }
  on Critical { emergency_stop; }
}

deploy Rover to RoverV1;
