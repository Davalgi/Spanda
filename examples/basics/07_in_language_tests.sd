module basics.math;

export fn clamp_speed(speed: Float) -> Float {
  return speed;
}

test "clamp accepts in-range speed" {
  assert(true);
}

robot TestRover {
  actuator wheels: DifferentialDrive;

  behavior run() {
    let _ = clamp_speed(0.5);
    wheels.stop();
  }
}
