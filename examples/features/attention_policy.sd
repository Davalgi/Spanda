// Feature: @policy(kind: "attention") — priority rules for mission focus
//
//   spanda check examples/features/attention_policy.sd
//   spanda reflex list --json
//
// Prefer @policy + `import std.policies.attention` (package spanda-policies).
// Legacy `attention_policy` still parses (lint warns).
// Docs: docs/cognitive-resilience-architecture.md
// Smoke: ./scripts/cognitive_resilience_smoke.sh

import std.policies.attention;

@policy(kind: "attention")
MissionFocus {
    rule suppress_low_priority;
    rule boost_critical_health;
}

robot Rover {
    sensor lidar: Lidar;
    actuator wheels: DifferentialDrive;
    safety { max_speed = 1.0 m/s; }
    behavior patrol() {
        loop every 100ms { }
    }
}
